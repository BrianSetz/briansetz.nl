<section id="about" class="py-20 bg-gray-50 dark:bg-gray-800">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-2">About</p>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Background</h2>
    <p class="text-gray-600 dark:text-gray-400 leading-relaxed max-w-3xl">{{ site.bio }}</p>

    <div class="mt-6 flex flex-wrap gap-2">
      {%- for interest in site.interests %}
      <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300">{{ interest }}</span>
      {%- endfor %}
    </div>

    <dl class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl">
      <div>
        <dt class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2">Office</dt>
        <dd class="text-gray-700 dark:text-gray-300">{{ site.office }}</dd>
      </div>
      <div>
        <dt class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2">Address</dt>
        <dd class="text-gray-700 dark:text-gray-300 not-italic">
          {{ site.address.street }}<br>
          {{ site.address.postal }} {{ site.address.city }}<br>
          {{ site.address.country }}
        </dd>
      </div>
      <div>
        <dt class="text-xs font-semibold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2">Email</dt>
        <dd><a href="mailto:{{ site.email | obfuscateEmail | safe }}" class="text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors">{{ site.email | obfuscateEmail | safe }}</a></dd>
      </div>
    </dl>
  </div>
</section>
