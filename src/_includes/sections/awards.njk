<section id="awards" class="py-16">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-2">Recognition</p>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">Honours, Awards &amp; Funds <span class="text-lg font-normal text-gray-400 dark:text-gray-500">({{ awards | length }})</span></h2>
    <ul role="list" class="space-y-6">
      {%- for award in awards %}
      <li class="group flex items-start gap-3 -mx-2 px-2 py-1 rounded-lg hover:bg-indigo-50/60 dark:hover:bg-indigo-900/20 transition-colors">
        <div class="flex-1">
          {%- if award.url %}
          <a href="{{ award.url }}" target="_blank" rel="noopener noreferrer"
             aria-label="{{ award.title }} (opens in new tab)"
             class="font-semibold text-gray-900 dark:text-gray-100 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            {{ award.title }}
          </a>
          {%- else %}
          <span class="font-semibold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{{ award.title }}</span>
          {%- endif %}
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{{ award.description }}</p>
        </div>
        {%- if award.year %}<span class="shrink-0 mt-0.5 text-xs font-medium px-2 py-0.5 rounded bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300"><time datetime="{{ award.year }}">{{ award.year }}</time></span>{%- endif %}
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>
