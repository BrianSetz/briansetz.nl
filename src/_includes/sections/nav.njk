<nav id="nav" class="sticky top-0 z-50 bg-white/90 dark:bg-gray-900/90 backdrop-blur border-b border-gray-100 dark:border-gray-700" aria-label="Main navigation">
  <div class="max-w-4xl mx-auto px-6 flex items-center justify-between h-14">
    <a href="/" class="font-semibold text-gray-900 dark:text-gray-100 tracking-tight" aria-current="page">{{ site.name }}</a>
    <div class="flex items-center gap-2">
      <ul role="list" id="nav-menu" class="hidden md:flex gap-6 text-sm text-gray-600 dark:text-gray-400">
        {%- for link in nav %}
        <li><a href="{{ link.href }}" class="hover:text-gray-900 dark:hover:text-gray-100 transition-colors">{{ link.label }}</a></li>
        {%- endfor %}
      </ul>
      <button id="theme-toggle" class="p-2 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors" aria-label="Switch to dark mode">
        <span id="theme-icon-sun" class="hidden">{%- include "icons/sun.svg" %}</span>
        <span id="theme-icon-moon" class="hidden">{%- include "icons/moon.svg" %}</span>
      </button>
      <button id="nav-toggle" class="md:hidden p-2 -mr-2 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-mobile">
        {%- include "icons/menu.svg" %}
      </button>
    </div>
  </div>
  <!-- Mobile menu -->
  <ul role="list" id="nav-mobile" class="hidden flex-col gap-2 px-6 pb-4 text-sm text-gray-600 dark:text-gray-400 md:hidden" aria-hidden="true">
    {%- for link in nav %}
    <li><a href="{{ link.href }}" class="block py-1 hover:text-gray-900 dark:hover:text-gray-100">{{ link.label }}</a></li>
    {%- endfor %}
  </ul>
</nav>
