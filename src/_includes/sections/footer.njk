<footer class="py-10 border-t border-gray-100 dark:border-gray-700">
  <div class="max-w-4xl mx-auto px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-8 mb-8 border-b border-gray-100 dark:border-gray-700">
      <div class="text-center hover:scale-105 transition-transform cursor-default">
        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ publications | length }}</p>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Publications</p>
      </div>
      <div class="text-center hover:scale-105 transition-transform cursor-default">
        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ supervision | length }}</p>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Students Supervised</p>
      </div>
      <div class="text-center hover:scale-105 transition-transform cursor-default">
        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ activities.venues | length }}</p>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Review Activities</p>
      </div>
      <div class="text-center hover:scale-105 transition-transform cursor-default">
        <p class="text-2xl font-bold text-indigo-600 dark:text-indigo-400">{{ projects | length }}</p>
        <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">Projects</p>
      </div>
    </div>
    <div class="text-center mb-8">
      <p class="text-gray-600 dark:text-gray-400">Interested in collaboration?</p>
      <a href="mailto:{{ site.email | obfuscateEmail | safe }}" class="inline-flex items-center gap-2 mt-3 px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 dark:bg-indigo-500 dark:hover:bg-indigo-600 text-white rounded-lg text-sm font-medium transition-colors">Get in touch</a>
    </div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-600 dark:text-gray-400">&copy; {% year %} {{ site.name }}. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="#top" class="text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 transition-colors">↑ Back to top</a>
        <a href="{{ site.social.github }}" target="_blank" rel="noopener noreferrer" aria-label="Source code on GitHub" class="text-gray-600 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">{% include "icons/github.svg" %}</a>
        <a href="/privacy/" class="text-sm text-gray-600 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors">Privacy</a>
      </div>
    </div>
  </div>
</footer>
