<section id="supervision" class="py-16">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">Supervision</h2>

    {%- set years = supervision | map("year") | unique %}

    {%- for year in years %}
    <div{% if not loop.first %} class="mt-8"{% endif %}>
      <p class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-4 border-b border-gray-200 dark:border-gray-600 pb-2"><time datetime="{{ year }}">{{ year }}</time></p>
      <ul role="list" class="space-y-4">
        {%- for item in supervision %}
          {%- if item.year == year %}
          <li>
            <cite class="font-medium text-gray-900 dark:text-gray-100 leading-snug not-italic block">{{ item.title }}</cite>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{{ item.authors }}</p>
            <span class="inline-block mt-1 text-xs font-medium px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400">{{ item.type }}</span>
          </li>
          {%- endif %}
        {%- endfor %}
      </ul>
    </div>
    {%- endfor %}
  </div>
</section>
