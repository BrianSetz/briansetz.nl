<section id="supervision" class="py-12 bg-gray-50 dark:bg-gray-800">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-2">Mentoring</p>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">Supervision <span class="text-lg font-normal text-gray-400 dark:text-gray-500">({{ supervision | length }})</span></h2>

    <ul role="list" class="space-y-4">
      {%- for item in supervision %}
      <li class="group flex items-start gap-3 -mx-2 px-2 py-1 rounded-lg hover:bg-indigo-50/60 dark:hover:bg-indigo-900/20 transition-colors">
        <div class="flex-1">
          <cite class="font-medium text-gray-900 dark:text-gray-100 leading-snug not-italic block group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{{ item.title }}</cite>
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{{ item.authors }}</p>
          <span class="inline-block mt-1 text-xs font-medium px-2 py-0.5 rounded bg-gray-100 dark:bg-gray-700 text-gray-500 dark:text-gray-400">{{ item.type }}</span>
        </div>
        <span class="shrink-0 mt-0.5 text-xs font-medium px-2 py-0.5 rounded bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300"><time datetime="{{ item.year }}">{{ item.year }}</time></span>
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>
