<section id="publications" class="py-20">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-2">Research</p>
    <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8">Publications <span class="text-lg font-normal text-gray-400 dark:text-gray-500">({{ publications | length }})</span></h2>

    <ul role="list" class="space-y-6">
      {%- for pub in publications %}
      <li class="group -mx-2 px-2 py-1 rounded-lg hover:bg-indigo-50/60 dark:hover:bg-indigo-900/20 transition-colors">
        <div class="flex items-start gap-3">
          <div class="flex-1">
            {%- if pub.url %}
            <a href="{{ pub.url }}" target="_blank" rel="noopener noreferrer"
               class="font-medium text-gray-900 dark:text-gray-100 underline decoration-gray-300 dark:decoration-gray-600 underline-offset-2 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 group-hover:decoration-indigo-300 dark:group-hover:decoration-indigo-400 transition-colors leading-snug">
              {{ pub.title }}<span class="sr-only"> (opens in new tab)</span>
            </a>
            {%- else %}
            <span class="font-medium text-gray-900 dark:text-gray-100 leading-snug group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{{ pub.title }}</span>
            {%- endif %}
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{{ pub.authors }}</p>
            <p class="text-sm text-gray-600 dark:text-gray-400">In <em>{{ pub.venue }}</em></p>
          </div>
          <span class="shrink-0 mt-0.5 text-xs font-medium px-2 py-0.5 rounded bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300"><time datetime="{{ pub.year }}">{{ pub.year }}</time></span>
        </div>
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>
