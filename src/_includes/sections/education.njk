<section id="education" class="py-16">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-2">Credentials</p>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">Education</h2>
    <ul role="list">
      {%- for edu in education %}
      <li class="group flex gap-5">
        <div class="flex flex-col items-center shrink-0">
          <span class="mt-1.5 w-2.5 h-2.5 rounded-full bg-indigo-500 dark:bg-indigo-400 shrink-0 group-hover:scale-125 transition-transform" aria-hidden="true"></span>
          {%- if not loop.last %}
          <div class="mt-1.5 w-0.5 flex-1 min-h-6 bg-indigo-200 dark:bg-indigo-800" aria-hidden="true"></div>
          {%- endif %}
        </div>
        <div class="pb-8">
          <time datetime="{{ edu.year }}" class="text-sm font-semibold text-gray-600 dark:text-gray-400">{{ edu.year }}</time>
          <h3 class="mt-0.5 font-semibold text-gray-900 dark:text-gray-100">{{ edu.degree }}</h3>
          <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{{ edu.institution }}</p>
        </div>
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>
