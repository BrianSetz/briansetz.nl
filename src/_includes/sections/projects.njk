<section id="projects" class="py-16">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8">Projects</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {%- for project in projects %}
      {%- if project.url %}
      <a href="{{ project.url }}" target="_blank" rel="noopener noreferrer"
         aria-label="{{ project.title }} (opens in new tab)"
         class="block p-6 bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 hover:border-gray-200 dark:hover:border-gray-600 hover:shadow-md transition-all group focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-indigo-600 dark:focus-visible:ring-indigo-400">
        <div class="mb-3">
          <h3 class="font-semibold text-gray-900 dark:text-gray-100 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">{{ project.title }}</h3>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{{ project.description }}</p>
      </a>
      {%- else %}
      <div class="block p-6 bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700">
        <div class="flex items-center gap-2 mb-3">
          <h3 class="font-semibold text-gray-900 dark:text-gray-100">{{ project.title }}</h3>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{{ project.description }}</p>
      </div>
      {%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>
