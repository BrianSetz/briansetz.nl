<section id="activities" class="py-16">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-4">Academic Activities</h2>
    <h3 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-4">{{ activities.role }}</h3>
    <ul role="list" class="flex flex-wrap gap-2">
      {%- for venue in activities.venues %}
      <li class="text-sm text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-2.5 py-1 rounded">{{ venue }}</li>
      {%- endfor %}
    </ul>
  </div>
</section>
