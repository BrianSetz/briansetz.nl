<section id="activities" class="py-12 bg-gray-50 dark:bg-gray-800">
  <div class="max-w-4xl mx-auto px-6">
    <p class="text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 mb-2">Service</p>
    <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-6">Academic Activities <span class="text-lg font-normal text-gray-400 dark:text-gray-500">({{ activities.venues | length }})</span></h2>
    <ul role="list" class="flex flex-wrap gap-2">
      {%- for venue in activities.venues %}
      <li class="text-sm text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 px-3 py-1.5 rounded hover:bg-indigo-50 dark:hover:bg-indigo-900/30 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">{{ venue }}</li>
      {%- endfor %}
    </ul>
  </div>
</section>
